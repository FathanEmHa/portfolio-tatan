# =============================================================================
# .dockerignore — portfolio-tatan
# =============================================================================
# Files listed here are NEVER sent to the Docker build daemon.
# This keeps the build context small and prevents secrets / dev artifacts
# from leaking into the image.
# =============================================================================

# Development dependencies (rebuilt inside the builder stage via npm ci)
node_modules/

# Previous production build — the builder stage runs `npm run build` fresh
dist/
dist-ssr/

# Version control
.git/
.gitignore

# Editor / IDE metadata
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (never bake secrets into an image)
.env
.env.*
!.env.example

# Docker files themselves (no need to copy these into the image)
Dockerfile
docker-compose.yml
.dockerignore

# README
README.md
